# PawStreak environment variables
# Copy this file to .env.local for local dev, never commit .env.local.
# In production (Vercel), set these in the Project Settings > Environment Variables UI.

# Supabase (frontend client only — anon key is safe to ship)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional: enable demo-only mode (skip Supabase entirely, even if keys are present)
# Set to "true" only for screenshots/local UI work; leave blank for normal use.
VITE_FORCE_DEMO_MODE=

# Sentry error monitoring (optional)
# When VITE_SENTRY_DSN is empty, error monitoring is a hard no-op (Sentry
# is not loaded, no events sent). Privacy contract enforced in
# src/lib/errorMonitoring.ts:
#   - never sends dog name, email, exact ZIP, lat/lng, or freeform user text
#   - session replay is disabled
#   - performance tracing is disabled
#   - user identification is not called
#   - URLs/breadcrumbs are scrubbed of query strings + input data
VITE_SENTRY_DSN=

# PostHog product analytics (optional)
# When VITE_POSTHOG_KEY is empty, analytics is a hard no-op (nothing is loaded
# or sent). Privacy contract enforced in src/lib/analytics.ts:
#   - never sends dog name, email, exact ZIP, or precise lat/lng
#   - autocapture and session recording are disabled
#   - respects DNT / Global Privacy Control
# Get the project key from your PostHog project settings.
VITE_POSTHOG_KEY=
# Defaults to https://us.i.posthog.com when blank. Set to https://eu.i.posthog.com
# (or your self-hosted host) if your project lives elsewhere.
VITE_POSTHOG_HOST=
